# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Neo4j connection (running as a systemd service in WSL2)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password_here

# Semantic Scholar API keys (only needed to re-run ingestion)
# Register free at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY_1=your_key_here
SEMANTIC_SCHOLAR_API_KEY_2=your_key_here
